<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="horizontal"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="18dp"
        android:layout_weight="1"
        android:background="@drawable/bg_panel_card"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:id="@+id/text_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/text_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_primary"
            android:textSize="40sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.kindlepanel.mode.dashboard.FlipDigitView
                android:id="@+id/digit_hour_tens"
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <com.kindlepanel.mode.dashboard.FlipDigitView
                android:id="@+id/digit_hour_ones"
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/text_time_colon"
                android:layout_width="26dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text=":"
                android:textColor="@color/text_secondary"
                android:textSize="56sp"
                android:textStyle="bold" />

            <com.kindlepanel.mode.dashboard.FlipDigitView
                android:id="@+id/digit_minute_tens"
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <com.kindlepanel.mode.dashboard.FlipDigitView
                android:id="@+id/digit_minute_ones"
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/bg_panel_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/image_weather_icon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_weather_unknown" />

        <TextView
            android:id="@+id/text_current_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_primary"
            android:textSize="44sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_weather_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/text_temp_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/text_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/accent"
            android:textSize="24sp" />
    </LinearLayout>

</LinearLayout>
