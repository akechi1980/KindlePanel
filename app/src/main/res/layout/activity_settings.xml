<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            style="@style/SettingsTitle"
            android:text="@string/settings_title" />

        <TextView
            style="@style/SettingsLabel"
            android:text="@string/settings_default_mode" />

        <Spinner
            android:id="@+id/spinner_default_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            style="@style/SettingsLabel"
            android:text="@string/settings_web_url" />

        <EditText
            android:id="@+id/edit_web_url"
            style="@style/SettingsEditText"
            android:hint="@string/settings_web_url_hint"
            android:inputType="textUri" />

        <TextView
            style="@style/SettingsLabel"
            android:text="@string/settings_web_refresh" />

        <EditText
            android:id="@+id/edit_web_refresh"
            style="@style/SettingsEditText"
            android:inputType="number" />

        <TextView
            style="@style/SettingsLabel"
            android:text="@string/settings_weather_city" />

        <EditText
            android:id="@+id/edit_weather_city"
            style="@style/SettingsEditText"
            android:inputType="text" />

        <TextView
            style="@style/SettingsLabel"
            android:text="@string/settings_weather_refresh" />

        <EditText
            android:id="@+id/edit_weather_refresh"
            style="@style/SettingsEditText"
            android:inputType="number" />

        <TextView
            style="@style/SettingsLabel"
            android:text="@string/settings_photo_directory" />

        <EditText
            android:id="@+id/edit_photo_directory"
            style="@style/SettingsEditText"
            android:hint="@string/settings_photo_directory_hint"
            android:inputType="text" />

        <TextView
            style="@style/SettingsLabel"
            android:text="@string/settings_photo_interval" />

        <EditText
            android:id="@+id/edit_photo_interval"
            style="@style/SettingsEditText"
            android:inputType="number" />

        <TextView
            style="@style/SettingsLabel"
            android:text="@string/settings_photo_mode" />

        <Spinner
            android:id="@+id/spinner_photo_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_keep_screen_on"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/settings_keep_screen_on"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_reset"
                style="@style/SettingsButton"
                android:text="@string/settings_reset" />

            <Button
                android:id="@+id/button_save"
                style="@style/SettingsButton"
                android:layout_marginStart="12dp"
                android:text="@string/settings_save" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>
