<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <!-- 模式内容统一放在这个容器里，由 MainActivity 负责切换。 -->
    <FrameLayout
        android:id="@+id/mode_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 右上角主操作浮层，默认隐藏，只在三击后短暂显示。 -->
    <LinearLayout
        android:id="@+id/overlay_menu"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="28dp"
        android:background="@drawable/bg_overlay_menu"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="18dp"
        android:visibility="gone">

        <Button
            android:id="@+id/button_settings"
            style="@style/OverlayMenuButton"
            android:text="@string/menu_settings" />

        <Button
            android:id="@+id/button_exit"
            style="@style/OverlayMenuButton"
            android:layout_marginTop="10dp"
            android:text="@string/menu_exit" />
    </LinearLayout>

    <!-- 右下角模式切换条，沿用和主浮层一致的轻量交互方式。 -->
    <LinearLayout
        android:id="@+id/overlay_mode_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_overlay_menu"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="14dp"
        android:visibility="gone">

        <Button
            android:id="@+id/button_mode_dashboard"
            style="@style/OverlayModeButton"
            android:text="@string/mode_dashboard" />

        <Button
            android:id="@+id/button_mode_web"
            style="@style/OverlayModeButton"
            android:layout_marginStart="8dp"
            android:text="@string/mode_web" />

        <Button
            android:id="@+id/button_mode_photo"
            style="@style/OverlayModeButton"
            android:layout_marginStart="8dp"
            android:text="@string/mode_photo" />
    </LinearLayout>

</FrameLayout>
